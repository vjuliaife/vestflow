# ─────────────────────────────────────────────────
#  VestFlow — environment configuration
#  Copy this file to .env.local and fill in values.
# ─────────────────────────────────────────────────

# ── Testnet (default) ─────────────────────────────
# Deployed testnet contract: CCZ6AE75C27DMB3SOIHK7WZSBUG3NQPVLHSVEBQ2FSAEVGRJ5TXAZWCX
NEXT_PUBLIC_CONTRACT_ID=

# Native XLM token address on Stellar testnet.
# Serves as the default token pre-filled in the UI, but any SEP-41 compliant token address is supported.
NEXT_PUBLIC_NATIVE_TOKEN=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Network: "testnet" or "mainnet" (default: testnet)
NEXT_PUBLIC_NETWORK=testnet

# ── Mainnet (uncomment when deploying to mainnet) ──
# Replace the values below with real mainnet addresses
# after completing the mainnet deployment checklist (see README).
#
# NEXT_PUBLIC_NETWORK=mainnet
# NEXT_PUBLIC_CONTRACT_ID=<your-mainnet-contract-id>
# NEXT_PUBLIC_NATIVE_TOKEN=CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA

# ── Notifications (optional) ──────────────────────
# SendGrid API key for email notifications
SENDGRID_API_KEY=

# Email address notifications will be sent from
NOTIFICATION_FROM_EMAIL=noreply@vestflow.xyz

# Base URL for notification links (default: https://vestflow.xyz)
NEXT_PUBLIC_BASE_URL=https://vestflow.xyz
